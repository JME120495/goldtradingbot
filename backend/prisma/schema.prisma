generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String?
  role              String   @default("CLIENT")
  passwordHash      String?
  phone             String?  @unique
  preferredCurrency String   @default("USD")
  refreshTokenHash  String? // hashed refresh token for rotation
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  licenses        License[]
  tradingAccounts TradingAccount[]
  payments        Payment[]
  supportTickets  SupportTicket[]
  affiliateData   Affiliate?
}

model Product {
  id          String   @id @default(uuid())
  name        String // e.g. "Gold Scalper MT5"
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans    ProductPlan[]
  licenses License[]
}

model ProductPlan {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  name       String // e.g. "Starter", "Standard", "Pro", "VIP"
  lotAllowed Float // 0.01, 0.10, 0.50, 1.00
  prices     String // JSON as string for SQLite compatibility: { weekly: 20, monthly: 59, quarterly: 149, biyearly: 249, yearly: 449 }
  isTrial    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  licenses License[]
}

model License {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  planId           String
  plan             ProductPlan     @relation(fields: [planId], references: [id])
  tradingAccountId String?
  tradingAccount   TradingAccount? @relation(fields: [tradingAccountId], references: [id])

  key        String    @unique @default(uuid())
  status     String    @default("ACTIVE")
  lotAllowed Float // Snapshot from plan at time of purchase
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  payments Payment[]
}

model TradingAccount {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  accountNumber String
  broker        String
  server        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  licenses License[]

  @@unique([accountNumber, broker])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  licenseId String?
  license   License? @relation(fields: [licenseId], references: [id])

  amount       Float
  currency     String  @default("USD")
  status       String  @default("PENDING")
  provider     String // STRIPE, PAYPAL, NOWPAYMENTS, FLUTTERWAVE
  providerTxId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Affiliate {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  code           String   @unique // ref/CODE
  commissionRate Float    @default(10.0)
  clicks         Int      @default(0)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales AffiliateSale[]
}

model AffiliateSale {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  amount      Float
  commission  Float
  isRenewal   Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Standalone license table for MT5 EA verification.
/// Decoupled from the User/Product system so that the EA
/// can do a fast, flat lookup without joins.
model Mt5License {
  id Int @id @default(autoincrement())

  // Client identity (flat — no FK to User for now)
  clientName     String  @db.VarChar(120)
  clientEmail    String  @db.VarChar(160)
  clientWhatsapp String? @db.VarChar(30)

  // MT5 account details
  accountNumber BigInt
  broker        String @default("") @db.VarChar(100)
  server        String @default("") @db.VarChar(100)

  // EA product (JMEGOLD_DUAL, GOLD_SCALPER, GOLDDOUBLESTOP, ALL)
  eaName String @default("ALL") @db.VarChar(60)

  // Plan & trading parameters
  plan String  @default("Starter") @db.VarChar(20)
  lot  Decimal @default(0.01) @db.Decimal(6, 2)

  // Status & validity
  status     String   @default("active") @db.VarChar(20)
  expiryDate DateTime @db.Date

  // Tracking (updated by the verify endpoint)
  lastCheckAt DateTime? @db.Timestamptz()
  lastCheckIp String?   @db.VarChar(60)
  checkCount  Int       @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz()
  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([accountNumber, eaName])
  @@index([expiryDate])
  @@map("mt5_licenses")
}

model Mt5AccountStat {
  id            Int    @id @default(autoincrement())
  accountNumber BigInt
  eaName        String @default("ALL") @db.VarChar(60)

  balance    Decimal @db.Decimal(12, 2)
  equity     Decimal @db.Decimal(12, 2)
  margin     Decimal @db.Decimal(12, 2)
  freeMargin Decimal @db.Decimal(12, 2)

  updatedAt DateTime @updatedAt @db.Timestamptz()

  @@unique([accountNumber, eaName])
  @@map("mt5_account_stats")
}

model Mt5Trade {
  ticket        BigInt @id
  accountNumber BigInt
  eaName        String @db.VarChar(60)

  symbol     String   @db.VarChar(20)
  type       String   @db.VarChar(10)
  volume     Decimal  @db.Decimal(6, 2)
  openPrice  Decimal  @db.Decimal(10, 5)
  closePrice Decimal  @db.Decimal(10, 5)
  openTime   DateTime
  closeTime  DateTime
  profit     Decimal  @db.Decimal(10, 2)
  commission Decimal  @db.Decimal(10, 2)
  swap       Decimal  @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([accountNumber])
  @@map("mt5_trades")
}
